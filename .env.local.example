# SADAM AI 프론트엔드 환경변수 (예시)
# 이 파일을 .env.local 로 복사하세요. (.env.local 은 git 에 올라가지 않습니다)
#   cp .env.local.example .env.local

# 백엔드 주소. next.config.ts 의 rewrite 가 /api/* 를 이 주소로 프록시한다(same-origin).
# → 배포(Vercel)에서도 이 값만 설정하면 CORS·쿠키 문제 없이 동작.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# (선택) 로컬 WSL 에서 Next dev 프록시가 느린 /messages 에 ECONNRESET 을 내면 1 로 설정.
# 그러면 프록시 대신 브라우저가 백엔드를 직접 호출한다(이때만 CORS_ORIGINS 필요).
# 배포(Vercel)에서는 설정하지 말 것 — 프록시 경유가 CORS·쿠키에 유리하다.
# NEXT_PUBLIC_DIRECT_API=1
